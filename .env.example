# ── Railway service variables (required) ─────────────────────────────────────
# Dashboard login. Binding the dashboard publicly without these engages
# Hermes' fail-closed auth gate and locks everyone out, so start.sh refuses
# to boot until they're set. Set in Railway → Variables.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
# EITHER a precomputed scrypt hash (preferred — no plaintext at rest):
#   python3 -c "from importlib import import_module; print(import_module('plugins.dashboard_auth.basic').hash_password('YOUR-PASSWORD'))"
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=scrypt$...
# OR a plaintext password (hashed in-memory at load):
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=use-a-long-random-string

# ── Recommended ──────────────────────────────────────────────────────────────
# Token-signing key for dashboard session cookies. Without it a random
# per-process secret is generated and logins don't survive redeploys.
#   openssl rand -base64 32
HERMES_DASHBOARD_BASIC_AUTH_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Everything below is OPTIONAL. Two ways to set keys, no CLI prompts needed:
#   1. Railway → Variables (process env). Good for infra-as-config; keys
#      live in Railway, not on the volume.
#   2. The admin dashboard (writes /data/.hermes/.env on the volume).
# Precedence: /data/.hermes/.env overrides a same-named Railway Variable —
# pick one home per key.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────────────────────
# Dashboard supports OpenRouter, DeepSeek, DashScope, GLM/Z.AI, Kimi,
# MiniMax, HuggingFace. OpenRouter is the easiest start (one key, all models).
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=google/gemma-3-1b-it:free

# ── Tool APIs ────────────────────────────────────────────────────────────────
PARALLEL_API_KEY=       # search
FIRECRAWL_API_KEY=      # scraping
FAL_KEY=                # image generation
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
HONCHO_API_KEY=         # cross-session user memory
GITHUB_TOKEN=           # higher GitHub API rate limits

# ── Gateway access ───────────────────────────────────────────────────────────
# false = new users land in the dashboard's pairing queue; approve them in the
#         Pairing page before they can chat with the bot. Safer default for a
#         publicly-addressable Telegram/Discord/etc bot.
# true  = anyone who finds your bot username can chat (and burn LLM credits).
GATEWAY_ALLOW_ALL_USERS=false
