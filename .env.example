# ── Railway service variable (required) ──────────────────────────────────────
# Cloudflare Tunnel token from Cloudflare Zero Trust → Networks → Tunnels.
# Set this in Railway → Variables; the container refuses to start without it.
TUNNEL_TOKEN=eyJhIjoi...

# ──────────────────────────────────────────────────────────────────────────────
# Everything below is OPTIONAL and managed by the admin dashboard, which
# writes /data/.hermes/.env on the persistent volume. Only set these here if
# you prefer file-based config — the dashboard UI is the recommended path.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────────────────────
# Dashboard supports OpenRouter, DeepSeek, DashScope, GLM/Z.AI, Kimi,
# MiniMax, HuggingFace. OpenRouter is the easiest start (one key, all models).
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=google/gemma-3-1b-it:free

# ── Tool APIs ────────────────────────────────────────────────────────────────
PARALLEL_API_KEY=       # search
FIRECRAWL_API_KEY=      # scraping
FAL_KEY=                # image generation
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
HONCHO_API_KEY=         # cross-session user memory
GITHUB_TOKEN=           # higher GitHub API rate limits

# ── Gateway access ───────────────────────────────────────────────────────────
# false = new users land in the dashboard's pairing queue; approve them in the
#         Users tab before they can chat with the bot. Safer default for a
#         publicly-addressable Telegram/Discord/etc bot.
# true  = anyone who finds your bot username can chat (and burn LLM credits).
GATEWAY_ALLOW_ALL_USERS=false
